# Local dev uses SQLite (no Docker required)
DATABASE_URL="file:./dev.db"

# For PostgreSQL via Docker, use instead:
# DATABASE_URL="postgresql://ani_user:ani_password@localhost:5432/ani_platform?schema=public"
# And change provider in prisma/schema.prisma to "postgresql"

JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_REFRESH_SECRET="change-this-to-another-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
