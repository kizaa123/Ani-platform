# PostgreSQL (required — schema.prisma uses provider = "postgresql")
#
# Render production DB (no shell needed):
#   1. Render Dashboard → your PostgreSQL service → Connections
#   2. Copy "External Database URL"
#   3. Paste below (or into backend/.env locally to run db:push from your machine)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
#
# Local PostgreSQL via Docker (docker compose up -d):
# DATABASE_URL="postgresql://ani_user:ani_password@localhost:5432/ani_platform?schema=public"
#
# Apply schema without Render shell:
#   - Deploy: `npm run build` on Render runs `prisma db push` automatically
#   - Local:  set DATABASE_URL above, then `npm run db:push`
DATABASE_URL="postgresql://ani_user:ani_password@localhost:5432/ani_platform?schema=public"

JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_REFRESH_SECRET="change-this-to-another-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
# In dev, loca.lt tunnel + LAN IPs are also allowed automatically.
# For production, set your live frontend URL(s), comma-separated:
# FRONTEND_URL="https://your-app.vercel.app"
